#!/bin/bash

REPOS=("." "APIServer" "ClientPython" "Frontend")
NAMES=("Intercom (root)" "APIServer" "ClientPython" "Frontend")

BOLD="\033[1m"
CYAN="\033[36m"
RED="\033[31m"
RESET="\033[0m"

overall=0

if [ $# -eq 0 ]; then
  echo "Usage: $0 <git command> [args...]"
  echo "Example: $0 status"
  echo "         $0 push"
  echo "         $0 commit -m \"message\""
  exit 1
fi

# Stamp the shared version into each sub-repo before committing so CI can read it
if [ "$1" = "commit" ]; then
  VERSION=$(get-version)
  echo -e "${BOLD}Stamping VERSION=${VERSION} into sub-repos${RESET}"
  for repo in "APIServer" "ClientPython" "Frontend"; do
    if [ -d "$repo/.git" ]; then
      echo "$VERSION" > "$repo/VERSION"
      git -C "$repo" add VERSION
    fi
  done
  echo
fi

for i in "${!REPOS[@]}"; do
  repo="${REPOS[$i]}"
  name="${NAMES[$i]}"

  if [ ! -d "$repo/.git" ]; then
    echo -e "${RED}=== $name — skipped (not a git repo) ===${RESET}"
    continue
  fi

  echo -e "${BOLD}${CYAN}=== $name ===${RESET}"
  git -C "$repo" "$@" || overall=$?
  echo
done

exit $overall
